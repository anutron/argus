{
  "name": "split-vertical",
  "title": "Two terminals (stacked)",
  "root": {
    "type": "split",
    "direction": "vertical",
    "sizes": [1, 1],
    "children": [
      { "type": "terminal", "cycle": true },
      { "type": "terminal", "cycle": true }
    ]
  },
  "hotkeys": {
    "tab": "cycle down",
    "ctrl-1": "focus top",
    "ctrl-2": "focus bottom"
  }
}
